rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 1-100 chars)
    //   - category: string (required, 1-50 chars)
    //   - thumbnail: string (required, valid URL)
    //   - images: list (required, strings)
    //   - overview: string (required, 1-500 chars)
    //   - problem: string (required, 1-1000 chars)
    //   - goal: string (required, 1-1000 chars)
    //   - process: string (required, 1-5000 chars)
    //   - result: string (required, 1-1000 chars)
    //   - tools: list (required, strings)
    //   - featured: bool (required)
    //   - createdAt: number (required, positive)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "thaxkd1@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidProject(data) {
      return hasRequiredFields(['title', 'category', 'thumbnail', 'images', 'overview', 'problem', 'goal', 'process', 'result', 'tools', 'featured', 'createdAt']) &&
             hasOnlyAllowedFields(['title', 'category', 'thumbnail', 'images', 'overview', 'problem', 'goal', 'process', 'result', 'tools', 'featured', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 50 &&
             isValidUrl(data.thumbnail) &&
             data.images is list &&
             data.overview is string && data.overview.size() > 0 && data.overview.size() <= 500 &&
             data.problem is string && data.problem.size() > 0 && data.problem.size() <= 1000 &&
             data.goal is string && data.goal.size() > 0 && data.goal.size() <= 1000 &&
             data.process is string && data.process.size() > 0 && data.process.size() <= 5000 &&
             data.result is string && data.result.size() > 0 && data.result.size() <= 1000 &&
             data.tools is list &&
             data.featured is bool &&
             data.createdAt is number && data.createdAt > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /projects/{projectId} {
      allow read: if true; // Publicly readable portfolio
      allow create: if isAdmin() && isValidProject(request.resource.data);
      allow update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
